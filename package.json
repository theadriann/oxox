{
  "name": "oxox",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "changeset": "changeset",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "package": "pnpm run build && electron-builder --mac --dir",
    "dist": "pnpm run dist:mac",
    "dist:mac": "pnpm run build && electron-builder --mac",
    "dist:mac:x64": "pnpm run build && electron-builder --mac --x64",
    "dist:mac:arm64": "pnpm run build && electron-builder --mac --arm64",
    "dist:mac:all": "pnpm run build && electron-builder --mac --x64 && electron-builder --mac --arm64",
    "release:version": "changeset version",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome format . --write"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@factory/droid-sdk": "link:../droid-sdk-typescript",
    "@fontpkg/sf-mono": "^18.0.0",
    "@fontsource-variable/figtree": "^5.2.10",
    "@fontsource/geist": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@json-render/core": "^0.16.0",
    "@json-render/react": "^0.16.0",
    "@pierre/diffs": "^1.1.13",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-virtual": "^3.13.23",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.6.0",
    "mobx": "^6.15.0",
    "mobx-react-lite": "^4.1.1",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.6",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "3.8.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "stream-json": "^2.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "uuid": "^11.1.0",
    "vaul": "^1.1.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@changesets/cli": "^2.30.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.theadriann.oxox",
    "productName": "OXOX",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "out/**",
      "node_modules/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icons/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
